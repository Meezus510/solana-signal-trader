# ============================================================
# Solana Trader — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- Birdeye market data API --------------------------------
# Obtain from: https://birdeye.so/
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ---- Jupiter API (optional — only needed for live swap execution) ----
# Obtain from: https://jup.ag/
JUPITER_API_KEY=your_jupiter_api_key_here

# ---- QuikNode RPC / WebSocket (optional — for faster Solana RPC) ----
# Obtain from: https://quicknode.com/
QUICKNODE_RPC_URL=https://your-endpoint.solana-mainnet.quiknode.pro/your-token
QUICKNODE_WSS_URL=wss://your-endpoint.solana-mainnet.quiknode.pro/your-token

# ---- Telegram user account ----------------------------------
# Obtain API ID and hash from: https://my.telegram.org/apps
TG_API_ID=12345678
TG_API_HASH=0123456789abcdef0123456789abcdef

# ---- Telegram channel to monitor ----------------------------
# Channel username (without @)
TG_CHANNEL=your_channel_username_here
